# Vendored bundles — treat as binary so git never rewrites line endings
# between Windows and Linux checkouts. The wiki's vendor manifest pins
# SHA-256 hashes on the on-disk content; CRLF/LF conversion would break
# the hash on the off-platform checkout.
examples/wiki/public/vendor/** -text binary

# Shell scripts MUST stay LF — they run inside Linux containers where
# bash chokes on CRLF with "$'\r': command not found".
*.sh text eol=lf

# Fuzz seed corpora are byte-exact fuzzer inputs (truncated JSON, NUL
# bytes, boundary sizes) — line-ending normalization would corrupt them.
.clusterfuzzlite/seeds/** -text

# Derived artifacts owned end-to-end by generators emit LF, so the
# on-disk file is pinned to LF on every platform.
CHANGELOG.md text eol=lf

# Native modules — always binary.
*.node binary
*.so binary
*.dylib binary
*.dll binary
*.a binary

# Standard binary types.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.gz binary
*.tar binary
*.tgz binary
*.pdf binary
